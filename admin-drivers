<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fetch Admin — Drivers</title>
<link rel="stylesheet" href="/admin-shared.css?v=3">
<script>const SUPABASE_URL = 'https://errbnpeswpjmdsvehduz.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVycmJucGVzd3BqbWRzdmVoZHV6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEyNDgzMDMsImV4cCI6MjA4NjgyNDMwM30.ZYeZUV6PFs_yATPMUisH9vzXwWaMpBUwEn6Dsy6F0z8';

function getToken() { return localStorage.getItem('fetch_admin_token'); }
function authHeaders() {
  return { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${getToken() || SUPABASE_KEY}` };
}
function guardAdmin() { if (!getToken()) { window.location.href = '/admin'; return false; } return true; }
function signOut() { localStorage.removeItem('fetch_admin_token'); localStorage.removeItem('fetch_admin_user'); window.location.href = '/admin'; }

async function sbGet(table, params = '') {
  const res = await fetch(`${SUPABASE_URL}/rest/v1/${table}${params}`, { headers: authHeaders() });
  return res.json();
}
async function sbPost(table, body) {
  const res = await fetch(`${SUPABASE_URL}/rest/v1/${table}`, { method: 'POST', headers: { ...authHeaders(), 'Prefer': 'return=representation' }, body: JSON.stringify(body) });
  return res.json();
}
async function sbPatch(table, id, body) {
  const res = await fetch(`${SUPABASE_URL}/rest/v1/${table}?id=eq.${id}`, { method: 'PATCH', headers: { ...authHeaders(), 'Prefer': 'return=representation' }, body: JSON.stringify(body) });
  return res.json();
}
async function sbDelete(table, id) { await fetch(`${SUPABASE_URL}/rest/v1/${table}?id=eq.${id}`, { method: 'DELETE', headers: authHeaders() }); }

function generateCode() { return 'FETCH-' + Math.random().toString(36).substring(2, 8).toUpperCase(); }
function formatZAR(amount) { return 'R' + parseFloat(amount || 0).toFixed(2); }
function timeAgo(dateStr) {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  return `${Math.floor(hrs / 24)}d ago`;
}
function formatDate(dateStr) {
  if (!dateStr) return '—';
  return new Date(dateStr).toLocaleDateString('en-ZA', { day: 'numeric', month: 'short', year: 'numeric' });
}
function statusPill(status) {
  const map = { pending:['#FFF8E6','#9A6500'], confirmed:['#E6F0FB','#1A5FA5'], preparing:['#FFF8E6','#9A6500'], ready:['#F3E6FB','#6B21A8'], picked_up:['#E6F9F0','#0A7A45'], delivered:['#E6F9F0','#0A7A45'], cancelled:['#FDECEA','#B91C1C'], active:['#E6F9F0','#0A7A45'], onboarding:['#F7F7F7','#8E8E8E'], paused:['#FFF8E6','#9A6500'], suspended:['#FDECEA','#B91C1C'], approved:['#E6F9F0','#0A7A45'], rejected:['#FDECEA','#B91C1C'], driver:['#E6F9F0','#0A7A45'], suspended_driver:['#FDECEA','#B91C1C'] };
  const [bg, color] = map[status] || ['#F7F7F7','#8E8E8E'];
  const label = status.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  return `<span style="background:${bg};color:${color};padding:3px 10px;border-radius:999px;font-size:11px;font-weight:700;white-space:nowrap">${label}</span>`;
}
function buildSidebar(activePage) {
  const pages = [
    { id:'dashboard', icon:'📊', label:'Dashboard',    href:'/admin/dashboard' },
    { id:'enquiries', icon:'📋', label:'Enquiries',    href:'/admin/enquiries' },
    { id:'stores',    icon:'🏪', label:'Stores',       href:'/admin/stores' },
    { id:'codes',     icon:'🎟️', label:'Invite Codes', href:'/admin/codes' },
    { id:'orders',    icon:'🛒', label:'Orders',       href:'/admin/orders' },
    { id:'drivers',   icon:'🚗', label:'Drivers',      href:'/admin/drivers' },
  ];
  const items = pages.map(p => `<a href="${p.href}" class="sidebar-item ${p.id===activePage?'active':''}"><span>${p.icon}</span><span>${p.label}</span></a>`).join('');
  return `<aside class="sidebar"><div class="sidebar-logo">FETCH<span>.</span></div><div class="sidebar-badge">Admin</div><nav class="sidebar-nav">${items}</nav><button class="sidebar-signout" onclick="signOut()">Sign Out</button></aside>`;
}
function showModal(html) {
  const overlay = document.createElement('div');
  overlay.id = 'modal-overlay';
  overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.75);z-index:1000;display:flex;align-items:center;justify-content:center;padding:24px;overflow-y:auto';
  overlay.innerHTML = `<div style="background:#fff;border-radius:20px;padding:40px;max-width:520px;width:100%;position:relative">${html}<button onclick="closeModal()" style="position:absolute;top:16px;right:16px;background:#f7f7f7;border:none;border-radius:50%;width:32px;height:32px;cursor:pointer;font-size:16px">✕</button></div>`;
  overlay.addEventListener('click', e => { if(e.target===overlay) closeModal(); });
  document.body.appendChild(overlay);
}
function closeModal() { const el = document.getElementById('modal-overlay'); if(el) el.remove(); }
function copyToClipboard(text, btn) {
  navigator.clipboard.writeText(text).then(() => { const o=btn.textContent; btn.textContent='Copied! ✓'; btn.style.background='#06C167'; btn.style.color='#fff'; setTimeout(()=>{btn.textContent=o;btn.style.background='';btn.style.color='';},2000); });
}
function whatsappLink(phone, code, ownerName, storeName) {
  const num = (phone||'').replace(/\D/g,'').replace(/^0/,'27');
  const msg = encodeURIComponent(`Hi ${ownerName}! 👋 Welcome to Fetch 🎉\n\nYour store *${storeName}* has been approved!\n\nDownload the Fetch app and enter your Partner Code:\n\n*${code}*\n\nYour code expires in 30 days. Reply if you need help!`);
  return `https://wa.me/${num}?text=${msg}`;
}
</script>
</head>
<body>
<div id="sidebar-wrap"></div>
<div class="main">
  <div class="topbar">
    <h1>Drivers <span id="driver-count" class="badge" style="display:none"></span></h1>
    <div class="topbar-right">
      <input type="text" class="search-input" placeholder="Search drivers..." oninput="filterDrivers(this.value)">
    </div>
  </div>
  <div class="content">
    <div class="stats-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:24px">
      <div class="stat-card"><div class="stat-label" style="color:#06C167">Active Drivers</div><div class="stat-num" id="d-active" style="color:#06C167">—</div></div>
      <div class="stat-card"><div class="stat-label">Total Deliveries</div><div class="stat-num" id="d-deliveries">—</div></div>
      <div class="stat-card"><div class="stat-label" style="color:#E74C3C">Suspended</div><div class="stat-num" id="d-suspended" style="color:#E74C3C">—</div></div>
    </div>
    <div class="table-card">
      <table>
        <thead><tr><th>Driver</th><th>Phone</th><th>Deliveries</th><th>Est. Earnings</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody id="drivers-tbody"><tr><td colspan="6" style="text-align:center;padding:40px;color:#8E8E8E">Loading...</td></tr></tbody>
      </table>
    </div>
    <p style="font-size:12px;color:#8E8E8E;margin-top:12px;text-align:center">* Earnings shown are estimates (15% of order total). Actual payouts processed separately.</p>
  </div>
</div>
<script>
  guardAdmin();
  document.getElementById('sidebar-wrap').innerHTML = buildSidebar('drivers');
  let allDrivers = [];

  async function loadDrivers() {
    const profiles = await sbGet('profiles', "?role=in.(driver,suspended_driver)&select=*&order=created_at.desc");
    if (!Array.isArray(profiles)) { allDrivers = []; renderDrivers(); return; }
    const deliveries = await sbGet('orders', '?status=eq.delivered&select=driver_id,total_amount');
    const deliveryMap = {};
    if (Array.isArray(deliveries)) {
      deliveries.forEach(o => {
        if (!o.driver_id) return;
        if (!deliveryMap[o.driver_id]) deliveryMap[o.driver_id] = { count: 0, earnings: 0 };
        deliveryMap[o.driver_id].count++;
        deliveryMap[o.driver_id].earnings += parseFloat(o.total_amount||0) * 0.15;
      });
    }
    allDrivers = profiles.map(p => ({ ...p, deliveries: deliveryMap[p.id]?.count||0, earnings: deliveryMap[p.id]?.earnings||0 }));
    const badge = document.getElementById('driver-count');
    badge.textContent = allDrivers.length; badge.style.display = 'inline-flex';
    document.getElementById('d-active').textContent = allDrivers.filter(d=>d.role==='driver').length;
    document.getElementById('d-suspended').textContent = allDrivers.filter(d=>d.role==='suspended_driver').length;
    document.getElementById('d-deliveries').textContent = allDrivers.reduce((s,d)=>s+d.deliveries,0);
    renderDrivers(allDrivers);
  }

  function filterDrivers(q) {
    renderDrivers(allDrivers.filter(d => (d.full_name||'').toLowerCase().includes(q.toLowerCase()) || (d.phone||'').includes(q)));
  }

  function renderDrivers(data) {
    const tbody = document.getElementById('drivers-tbody');
    if (!data || !data.length) { tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:48px;color:#8E8E8E"><div style="font-size:32px;margin-bottom:12px">🚗</div>No drivers found</td></tr>`; return; }
    tbody.innerHTML = data.map(d => `<tr>
      <td>
        <div style="display:flex;align-items:center;gap:10px">
          <div style="width:36px;height:36px;border-radius:50%;background:rgba(6,193,103,0.15);display:flex;align-items:center;justify-content:center;font-weight:800;color:#06C167;font-size:14px;flex-shrink:0">${(d.full_name||'?').charAt(0).toUpperCase()}</div>
          <div><div style="font-weight:700">${d.full_name||'Unknown'}</div><div style="font-size:12px;color:#8E8E8E">${d.id.slice(0,8)}...</div></div>
        </div>
      </td>
      <td>${d.phone?`<a href="https://wa.me/${(d.phone).replace(/\D/g,'').replace(/^0/,'27')}" target="_blank" style="color:#06C167;font-weight:600;text-decoration:none">${d.phone}</a>`:'—'}</td>
      <td><strong>${d.deliveries}</strong> <span style="color:#8E8E8E;font-size:12px">deliveries</span></td>
      <td style="color:#06C167;font-weight:700">~${formatZAR(d.earnings)}</td>
      <td>${statusPill(d.role)}</td>
      <td>
        <div style="display:flex;gap:6px">
          ${d.role==='driver'?`<button class="btn btn-red btn-sm" onclick="suspendDriver('${d.id}','${d.full_name||'Driver'}')">🚫 Suspend</button>`:`<button class="btn btn-green btn-sm" onclick="reinstateDriver('${d.id}')">↩ Reinstate</button>`}
        </div>
      </td>
    </tr>`).join('');
  }

  async function suspendDriver(id, name) {
    if (!confirm(`Suspend ${name}?`)) return;
    await sbPatch('profiles', id, { role: 'suspended_driver' }); loadDrivers();
  }
  async function reinstateDriver(id) { await sbPatch('profiles', id, { role: 'driver' }); loadDrivers(); }
  loadDrivers();
</script>
</body>
</html>
